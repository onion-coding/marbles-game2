# Marbles Game — environment variables
#
# Copy this file to .env (which is gitignored), fill in the values for
# your machine, and load it before running `rgsd`, `replayd`, `roundd`,
# or `make docker-up`. None of these defaults are safe for production.

# ============================================================
# rgsd — operator-facing daemon
# ============================================================

# Required: HTTP listen address. Use :8090 in dev; bind to 127.0.0.1
# behind a reverse proxy in production.
RGSD_ADDR=:8090

# Required: absolute path to the Godot 4.6.2 executable. The container
# image bundles its own Godot — this is for local-host runs only.
RGSD_GODOT_BIN=/usr/local/bin/godot

# Required: absolute path to the game/ project directory.
RGSD_PROJECT_PATH=/srv/marbles-game/game

# Required: where per-round audit entries go (manifest.json + replay.bin).
# In production this becomes an object-store URI; today it's a local dir.
RGSD_REPLAY_ROOT=/var/lib/marbles-game/replays

# Configured RTP in basis points (9500 = 95.00 %).
RGSD_RTP_BPS=9500

# Stake per filled seat (in operator currency units; integer).
RGSD_BUY_IN=100

# Marbles per round (max 20 — fairness derivation is sized for 20).
RGSD_MARBLES=20

# HMAC key for /v1/* request signing. Hex-encoded, 32 bytes
# (64 hex chars). Empty disables auth — DO NOT do that in production
# (rgsd will warn loudly on every boot if you do).
#
# Generate one with:
#   openssl rand -hex 32
RGSD_HMAC_SECRET=

# ============================================================
# replayd — archive HTTP / WS server
# ============================================================

# These mirror the rgsd flags. Use a different listen port if running
# both rgsd and replayd on the same host.
REPLAYD_ADDR=:8087
REPLAYD_REPLAY_ROOT=/var/lib/marbles-game/replays

# Optional: Godot Web export root. If set, replayd serves it from /
# (so the same origin serves both the game bundle and the API). Useful
# for quick demos; in production the front-end usually lives behind a
# CDN.
REPLAYD_STATIC_ROOT=

# Optional: TCP port that the sim connects back on for live streaming.
# Leave empty to disable live streaming.
REPLAYD_STREAM_TCP=:8088

# ============================================================
# Postgres (phase 1 — durable state)
# ============================================================

# These are read by the docker-compose stack. They are NOT yet read by
# rgsd itself — phase 1 of the roadmap will wire rgsd to Postgres.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=marbles
POSTGRES_USER=marbles
POSTGRES_PASSWORD=change-me-locally

# ============================================================
# Prometheus / Grafana (local dev observability)
# ============================================================

# Port the Prometheus container exposes to the host.
PROMETHEUS_PORT=9090

# Port the Grafana container exposes; default Grafana login admin/admin.
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
