# Godot 4+ ignores
# https://github.com/github/gitignore/blob/main/Godot.gitignore

# Godot-specific ignores
.godot/
.import/

# Imported translations (automatically generated from CSV files)
export.cfg
export_presets.cfg

# Mono-specific ignores (if C# is added later)
.mono/
data_*/
mono_crash.*.json

# System/editor junk
.vs/
.vscode/
*.swp
*~

# Logs & temp files
logs/
*.log
Thumbs.db
.DS_Store

# Godot 4 editor cache
game/.godot/
