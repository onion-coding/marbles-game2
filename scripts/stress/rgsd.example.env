# Example rgsd Configuration for Stress Testing
#
# These are suggested environment variables / command-line flags
# to start rgsd for stress testing.

# HTTP listen address and port
RGSD_HTTP=127.0.0.1:8080

# HMAC secret for signing /v1/* endpoints
# IMPORTANT: Must match the -hmac-secret flag in the stress test
RGSD_HMAC_SECRET=dev-secret

# Data directory (where rounds/bets are persisted)
# Can be an in-memory store for testing
RGSD_DATA_DIR=/tmp/rgsd-stress-test

# Optional: Number of worker goroutines
RGSD_WORKERS=16

# Optional: Max connections in pool
RGSD_MAX_CONNECTIONS=100

# Optional: Request timeout
RGSD_REQUEST_TIMEOUT=30s

# Optional: Enable debug logging (verbose)
RGSD_DEBUG=false

# Optional: Log level (debug, info, warn, error)
RGSD_LOG_LEVEL=info

# Example startup command:
#
# rgsd \
#   --http=127.0.0.1:8080 \
#   --hmac-secret=dev-secret \
#   --data-dir=/tmp/rgsd-stress-test \
#   --workers=16 \
#   --max-connections=100
